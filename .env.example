# ─────────────────────────────────────────────────────────────
#  IBM Watsonx.ai – Interview Trainer Agent
#  Copy this file to .env and fill in your real credentials.
#  Never commit .env to source control.
# ─────────────────────────────────────────────────────────────

# IBM Cloud API Key  (IAM → Manage → API keys)
IBM_API_KEY=your_ibm_api_key_here

# Watsonx project ID  (Watsonx.ai → Manage → Project settings)
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# Watsonx endpoint (region-specific)
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Flask secret key – change this to a strong random string
FLASK_SECRET_KEY=change_me_to_a_long_random_string_in_production

# Flask runtime settings
FLASK_DEBUG=False
FLASK_PORT=5000
